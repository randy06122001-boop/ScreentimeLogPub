{
  "name": "screen-time-tracker",
  "version": "1.0.0",
  "description": "Cross-platform desktop screen time tracker",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "desktop-idle": "^1.3.0",
    "electron-store": "^8.1.0",
    "auto-launch": "^5.0.6",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "csv-writer": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33"
  },
  "build": {
    "appId": "com.screentime.tracker",
    "productName": "Screen Time Tracker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
