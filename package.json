{
  "name": "screen-time-tracker",
  "version": "2.1.0",
  "description": "Cross-platform desktop screen time tracker",
  "main": "./src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "better-sqlite3": "^9.6.0",
    "csv-writer": "^1.6.0",
    "electron-store": "^8.2.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4"
  },
  "optionalDependencies": {
    "desktop-idle": "^1.3.0",
    "active-win": "^8.2.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.screentime.tracker",
    "productName": "Screen Time Tracker v2.1.0",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
