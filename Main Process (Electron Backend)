const { jsPDF } = require('jspdf');
require('jspdf-autotable');
const createCsvWriter = require('csv-writer').createObjectCsvWriter;
const { format, parseISO } = require('date-fns');
const fs = require('fs');
const path = require('path');

/**
 * Export service for generating PDF and CSV reports
 */
class ExportService {
  /**
   * Creates a new export service
   * @param {ScreenTimeDatabase} database - Database instance
   */
  constructor(database) {
    this.database = database;
  }

  /**
   * Formats duration in seconds to readable string
   * @param {number} seconds - Duration in seconds
   * @returns {string} Formatted duration
   */
  formatDuration(seconds) {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    const secs = seconds % 60;

    const parts = [];
    if (hours > 0) parts.push(`${hours}h`);
    if (minutes > 0) parts.push(`${minutes}m`);
    if (secs > 0 || parts.length === 0) parts.push(`${secs}s`);

    return parts.join(' ');
  }

  /**
   * Exports data to PDF
   * @param {string} startDate - Start date (YYYY-MM-DD)
   * @param {string} endDate - End date (YYYY-MM-DD)
   * @param {string} filePath - Output file path
   * @returns {Promise<void>}
   */
  async exportToPDF(startDate, endDate, filePath) {
    try {
      const sessions = this.database.getSessionsByDateRange(startDate, endDate);
      const summaries = this.database.getDailySummaries(startDate, endDate);

      const doc = new jsPDF();
      const pageWidth = doc.internal.pageSize.getWidth();

      // Title
      doc.setFontSize(20);
      doc.setTextColor(59, 130, 246);
      doc.text('Screen Time Report', pageWidth / 2, 20, { align: 'center' });

      // Date range
      doc.setFontSize(12);
      doc.setTextColor(100);
      doc.text(`${startDate} to ${endDate}`, pageWidth / 2, 30, { align: 'center' });

      // Summary statistics
      const totalDuration = summaries.reduce((sum, s) => sum + s.total_duration, 0);
      const totalSessions = summaries.reduce((sum, s) => sum + s.session_count, 0);
      const avgDaily = summaries.length > 0 ? totalDuration / summaries.length : 0;

      doc.setFontSize(14);
      doc.setTextColor(0);
      doc.text('Summary', 14, 45);

      doc.setFontSize(11);
      doc.text(`Total Screen Time: ${this.formatDuration(totalDuration)}`, 14, 55);
      doc.text(`Total Sessions: ${totalSessions}`, 14, 62);
      doc.text(`Average Daily Usage: ${this.formatDuration(Math.floor(avgDaily))}`, 14, 69);
      doc.text(`Days Tracked: ${summaries.length}`, 14, 76);

      // Daily summaries table
      doc.setFontSize(14);
      doc.text('Daily Summary', 14, 90);

      const dailyTableData = summaries.map(summary => [
        summary.date,
        this.formatDuration(summary.total_duration),
        summary.session_count.toString(),
        this.formatDuration(summary.average_session)
      ]);

      doc.autoTable({
        startY: 95,
        head: [['Date', 'Total Time', 'Sessions', 'Avg Session']],
        body: dailyTableData,
        theme: 'striped',
        headStyles: { fillColor: [59, 130, 246] },
        styles: { fontSize: 10 }
      });

      // Session details on new page
      doc.addPage();
      doc.setFontSize(14);
      doc.text('Session Details', 14, 20);

      const sessionTableData = sessions.map(session => [
        session.date,
        format(parseISO(session.start_time), 'HH:mm:ss'),
        session.end_time ? format(parseISO(session.end_time), 'HH:mm:ss') : 'Active',
        this.formatDuration(session.duration)
      ]);

      doc.autoTable({
        startY: 25,
        head: [['Date', 'Start Time', 'End Time', 'Duration']],
        body: sessionTableData,
        theme: 'striped',
        headStyles: { fillColor: [59, 130, 246] },
        styles: { fontSize: 9 }
      });

      // Footer
      const pageCount = doc.internal.getNumberOfPages();
      for (let i = 1; i <= pageCount; i++) {
        doc.setPage(i);
        doc.setFontSize(8);
        doc.setTextColor(150);
        doc.text(
          `Generated on ${format(new Date(), 'yyyy-MM-dd HH:mm:ss')} | Page ${i} of ${pageCount}`,
          pageWidth / 2,
          doc.internal.pageSize.getHeight() - 10,
          { align: 'center' }
        );
      }

      doc.save(filePath);
      console.log(`PDF exported to: ${filePath}`);
    } catch (error) {
      console.error('Error exporting to PDF:', error);
      throw error;
    }
  }

  /**
   * Exports data to CSV
   * @param {string} startDate - Start date (YYYY-MM-DD)
   * @param {string} endDate - End date (YYYY-MM-DD)
   * @param {string} filePath - Output file path
   * @returns {Promise<void>}
   */
  async exportToCSV(startDate, endDate, filePath) {
    try {
      const sessions = this.database.getSessionsByDateRange(startDate, endDate);

      const csvWriter = createCsvWriter({
        path: filePath,
        header: [
          { id: 'id', title: 'Session ID' },
          { id: 'date', title: 'Date' },
          { id: 'start_time', title: 'Start Time' },
          { id: 'end_time', title: 'End Time' },
          { id: 'duration', title: 'Duration (seconds)' },
          { id: 'duration_formatted', title: 'Duration (formatted)' }
        ]
      });

      const records = sessions.map(session => ({
        id: session.id,
        date: session.date,
        start_time: session.start_time,
        end_time: session.end_time || 'Active',
        duration: session.duration,
        duration_formatted: this.formatDuration(session.duration)
      }));

      await csvWriter.writeRecords(records);
      console.log(`CSV exported to: ${filePath}`);
    } catch (error) {
      console.error('Error exporting to CSV:', error);
      throw error;
    }
  }
}

module.exports = ExportService;

