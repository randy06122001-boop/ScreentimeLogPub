const desktopIdle = require('desktop-idle');

/**
 * @typedef {Object} ActivityMonitorConfig
 * @property {ScreenTimeDatabase} database - Database instance
 * @property {Store} store - Electron store instance
 * @property {Function} onSessionUpdate - Callback for session updates
 * @property {Function} onSessionEnd - Callback when session ends
 */

/**
 * @typedef {Object} CurrentSession
 * @property {number} id - Session ID
 * @property {Date} startTime - Session start time
 * @property {number} duration - Current duration in seconds
 */

/**
 * Activity monitor service for tracking screen time
 */
class ActivityMonitor {
  /**
   * Creates a new activity monitor
   * @param {ActivityMonitorConfig} config - Configuration object
   */
  constructor(config) {
    this.database = config.database;
    this.store = config.store;
    this.onSessionUpdate = config.onSessionUpdate || (() => {});
    this.onSessionEnd = config.onSessionEnd || (() => {});

    this.currentSessionId = null;
    this.currentSessionStart = null;
    this.monitorInterval = null;
    this.saveInterval = null;
    this.paused = false;
    this.monitoring = false;
    this.lastActivityTime = Date.now();

    // Load settings
    this.idleThreshold = this.store.get('idleThreshold', 300);
    this.minSessionDuration = this.store.get('minSessionDuration', 60);
    this.scheduledPauses = this.store.get('scheduledPauses', []);
  }

  /**
   * Starts the activity monitoring
   * @returns {void}
   */
  start() {
    if (this.monitoring) return;

    this.monitoring = true;
    console.log('Activity monitoring started');

    // Check for activity every second
    this.monitorInterval = setInterval(() => {
      this.checkActivity();
    }, 1000);

    // Save session data every 30 seconds
    this.saveInterval = setInterval(() => {
      this.saveCurrentSession();
    }, 30000);

    // Initial check
    this.checkActivity();
  }

  /**
   * Stops the activity monitoring
   * @returns {void}
   */
  stop() {
    this.monitoring = false;

    if (this.monitorInterval) {
      clearInterval(this.monitorInterval);
      this.monitorInterval = null;
    }

    if (this.saveInterval) {
      clearInterval(this.saveInterval);
      this.saveInterval = null;
    }

    // End current session if active
    if (this.currentSessionId) {
      this.endCurrentSession();
    }

    console.log('Activity monitoring stopped');
  }

  /**
   * Pauses the activity monitoring
   * @returns {void}
   */
  pause() {
    if (this.paused) return;

    this.paused = true;
    
    // End current session
    if (this.currentSessionId) {
      this.endCurrentSession();
    }

    console.log('Activity monitoring paused');
  }

  /**
   * Resumes the activity monitoring
   * @returns {void}
   */
  resume() {
    if (!this.paused) return;

    this.paused = false;
    this.lastActivityTime = Date.now();
    console.log('Activity monitoring resumed');
  }

  /**
   * Checks if monitoring is paused
   * @returns {boolean} True if paused
   */
  isPaused() {
    return this.paused;
  }

  /**
   * Checks if monitoring is active
   * @returns {boolean} True if monitoring
   */
  isMonitoring() {
    return this.monitoring;
  }

  /**
   * Gets the current session information
   * @returns {CurrentSession|null} Current session or null
   */
  getCurrentSession() {
    if (!this.currentSessionId || !this.currentSessionStart) {
      return null;
    }

    const duration = Math.floor((Date.now() - this.currentSessionStart.getTime()) / 1000);

    return {
      id: this.currentSessionId,
      startTime: this.currentSessionStart,
      duration
    };
  }

  /**
   * Updates monitor settings
   * @param {Object} settings - New settings
   * @returns {void}
   */
  updateSettings(settings) {
    if (settings.idleThreshold !== undefined) {
      this.idleThreshold = settings.idleThreshold;
    }
    if (settings.minSessionDuration !== undefined) {
      this.minSessionDuration = settings.minSessionDuration;
    }
    if (settings.scheduledPauses !== undefined) {
      this.scheduledPauses = settings.scheduledPauses;
    }
  }

  /**
   * Checks user activity and manages sessions
   * @returns {void}
   */
  checkActivity() {
    if (this.paused) return;

    // Check for scheduled pauses
    if (this.isInScheduledPause()) {
      if (this.currentSessionId) {
        this.endCurrentSession();
      }
      return;
    }

    try {
      const idleTime = desktopIdle.getIdleTime();
      const isIdle = idleTime >= this.idleThreshold * 1000;

      if (isIdle) {
        // User is idle
        if (this.currentSessionId) {
          this.endCurrentSession();
        }
      } else {
        // User is active
        this.lastActivityTime = Date.now();

        if (!this.currentSessionId) {
          this.startNewSession();
        } else {
          this.updateSession();
        }
      }
    } catch (error) {
      console.error('Error checking activity:', error);
    }
  }

  /**
   * Checks if current time is within a scheduled pause
   * @returns {boolean} True if in scheduled pause
   */
  isInScheduledPause() {
    if (!this.scheduledPauses || this.scheduledPauses.length === 0) {
      return false;
    }

    const now = new Date();
    const currentTime = now.getHours() * 60 + now.getMinutes();
    const currentDay = now.getDay();

    for (const pause of this.scheduledPauses) {
      if (!pause.enabled) continue;
      if (pause.days && !pause.days.includes(currentDay)) continue;

      const [startHour, startMin] = pause.startTime.split(':').map(Number);
      const [endHour, endMin] = pause.endTime.split(':').map(Number);

      const startMinutes = startHour * 60 + startMin;
      const endMinutes = endHour * 60 + endMin;

      if (currentTime >= startMinutes && currentTime < endMinutes) {
        return true;
      }
    }

    return false;
  }

  /**
   * Starts a new session
   * @returns {void}
   */
  startNewSession() {
    try {
      this.currentSessionStart = new Date();
      this.currentSessionId = this.database.startSession(this.currentSessionStart);
      
      console.log(`Started new session: ${this.currentSessionId}`);
      
      this.onSessionUpdate(this.getCurrentSession());
    } catch (error) {
      console.error('Error starting session:', error);
    }
  }

  /**
   * Updates the current session
   * @returns {void}
   */
  updateSession() {
    if (!this.currentSessionId) return;

    const session = this.getCurrentSession();
    this.onSessionUpdate(session);
  }

  /**
   * Saves the current session to database
   * @returns {void}
   */
  saveCurrentSession() {
    if (!this.currentSessionId || !this.currentSessionStart) return;

    try {
      const duration = Math.floor((Date.now() - this.currentSessionStart.getTime()) / 1000);
      this.database.updateSessionDuration(this.currentSessionId, duration);
    } catch (error) {
      console.error('Error saving session:', error);
    }
  }

  /**
   * Ends the current session
   * @returns {void}
   */
  endCurrentSession() {
    if (!this.currentSessionId) return;

    try {
      const session = this.database.endSession(this.currentSessionId);
      
      // Check if session meets minimum duration
      if (session && session.duration < this.minSessionDuration) {
        // Delete short session
        this.database.db.prepare('DELETE FROM sessions WHERE id = ?').run(this.currentSessionId);
        console.log(`Deleted short session: ${this.currentSessionId} (${session.duration}s)`);
      } else if (session) {
        console.log(`Ended session: ${this.currentSessionId} (${session.duration}s)`);
        this.onSessionEnd(session);
      }

      this.currentSessionId = null;
      this.currentSessionStart = null;
    } catch (error) {
      console.error('Error ending session:', error);
    }
  }
}

module.exports = ActivityMonitor;

