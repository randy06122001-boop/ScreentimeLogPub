const { app, BrowserWindow, ipcMain, Tray, Menu, nativeImage } = require('electron');
const path = require('path');
const AutoLaunch = require('auto-launch');
const Database = require('./database');
const ActivityMonitor = require('./activityMonitor');
const ExportService = require('./exportService');
const Store = require('electron-store');

/**
 * @typedef {Object} AppState
 * @property {BrowserWindow|null} mainWindow - Main application window
 * @property {Tray|null} tray - System tray instance
 * @property {Database|null} database - Database instance
 * @property {ActivityMonitor|null} activityMonitor - Activity monitor instance
 * @property {ExportService|null} exportService - Export service instance
 * @property {Store|null} store - Electron store for settings
 * @property {AutoLaunch|null} autoLauncher - Auto-launch instance
 */

/** @type {AppState} */
const appState = {
  mainWindow: null,
  tray: null,
  database: null,
  activityMonitor: null,
  exportService: null,
  store: null,
  autoLauncher: null
};

/**
 * Creates the main application window
 * @returns {void}
 */
function createWindow() {
  appState.mainWindow = new BrowserWindow({
    width: 1200,
    height: 800,
    minWidth: 800,
    minHeight: 600,
    webPreferences: {
      preload: path.join(__dirname, 'preload.js'),
      contextIsolation: true,
      nodeIntegration: false
    },
    icon: path.join(__dirname, '../../assets/icon.png'),
    show: false,
    frame: true,
    titleBarStyle: 'default'
  });

  // Load the renderer
  if (process.env.NODE_ENV === 'development') {
    appState.mainWindow.loadURL('http://localhost:3000');
    appState.mainWindow.webContents.openDevTools();
  } else {
    appState.mainWindow.loadFile(path.join(__dirname, '../../dist/index.html'));
  }

  appState.mainWindow.once('ready-to-show', () => {
    appState.mainWindow.show();
  });

  // Minimize to tray instead of closing
  appState.mainWindow.on('close', (event) => {
    if (!app.isQuitting) {
      event.preventDefault();
      appState.mainWindow.hide();
    }
  });

  appState.mainWindow.on('closed', () => {
    appState.mainWindow = null;
  });
}

/**
 * Creates the system tray with context menu
 * @returns {void}
 */
function createTray() {
  const iconPath = path.join(__dirname, '../../assets/tray-icon.png');
  const trayIcon = nativeImage.createFromPath(iconPath);
  
  appState.tray = new Tray(trayIcon.resize({ width: 16, height: 16 }));
  
  const contextMenu = Menu.buildFromTemplate([
    {
      label: 'Open Screen Time Tracker',
      click: () => {
        if (appState.mainWindow) {
          appState.mainWindow.show();
          appState.mainWindow.focus();
        }
      }
    },
    {
      label: 'Current Session',
      enabled: false,
      id: 'current-session'
    },
    { type: 'separator' },
    {
      label: 'Pause Tracking',
      type: 'checkbox',
      checked: false,
      click: (menuItem) => {
        if (menuItem.checked) {
          appState.activityMonitor.pause();
        } else {
          appState.activityMonitor.resume();
        }
        updateTrayMenu();
      }
    },
    { type: 'separator' },
    {
      label: 'Settings',
      click: () => {
        if (appState.mainWindow) {
          appState.mainWindow.show();
          appState.mainWindow.webContents.send('navigate', 'settings');
        }
      }
    },
    { type: 'separator' },
    {
      label: 'Quit',
      click: () => {
        app.isQuitting = true;
        app.quit();
      }
    }
  ]);

  appState.tray.setContextMenu(contextMenu);
  appState.tray.setToolTip('Screen Time Tracker');

  appState.tray.on('double-click', () => {
    if (appState.mainWindow) {
      appState.mainWindow.show();
      appState.mainWindow.focus();
    }
  });
}

/**
 * Updates the tray menu with current session information
 * @returns {void}
 */
function updateTrayMenu() {
  if (!appState.tray) return;

  const currentSession = appState.activityMonitor.getCurrentSession();
  const isPaused = appState.activityMonitor.isPaused();

  const contextMenu = Menu.buildFromTemplate([
    {
      label: 'Open Screen Time Tracker',
      click: () => {
        if (appState.mainWindow) {
          appState.mainWindow.show();
          appState.mainWindow.focus();
        }
      }
    },
    {
      label: currentSession 
        ? `Current Session: ${formatDuration(currentSession.duration)}`
        : 'No Active Session',
      enabled: false
    },
    { type: 'separator' },
    {
      label: isPaused ? 'Resume Tracking' : 'Pause Tracking',
      click: () => {
        if (isPaused) {
          appState.activityMonitor.resume();
        } else {
          appState.activityMonitor.pause();
        }
        updateTrayMenu();
      }
    },
    { type: 'separator' },
    {
      label: 'Settings',
      click: () => {
        if (appState.mainWindow) {
          appState.mainWindow.show();
          appState.mainWindow.webContents.send('navigate', 'settings');
        }
      }
    },
    { type: 'separator' },
    {
      label: 'Quit',
      click: () => {
        app.isQuitting = true;
        app.quit();
      }
    }
  ]);

  appState.tray.setContextMenu(contextMenu);
}

/**
 * Formats duration in seconds to human-readable string
 * @param {number} seconds - Duration in seconds
 * @returns {string} Formatted duration string
 */
function formatDuration(seconds) {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;

  if (hours > 0) {
    return `${hours}h ${minutes}m`;
  } else if (minutes > 0) {
    return `${minutes}m ${secs}s`;
  }
  return `${secs}s`;
}

/**
 * Initializes the application services
 * @returns {Promise<void>}
 */
async function initializeServices() {
  try {
    // Initialize store for settings
    appState.store = new Store({
      defaults: {
        idleThreshold: 300,
        minSessionDuration: 60,
        autoStart: false,
        darkMode: false,
        dataRetentionDays: 365,
        scheduledPauses: []
      }
    });

    // Initialize database
    const dbPath = path.join(app.getPath('userData'), 'screentime.db');
    appState.database = new Database(dbPath);

    // Initialize export service
    appState.exportService = new ExportService(appState.database);

    // Initialize activity monitor
    appState.activityMonitor = new ActivityMonitor({
      database: appState.database,
      store: appState.store,
      onSessionUpdate: (session) => {
        if (appState.mainWindow) {
          appState.mainWindow.webContents.send('session-update', session);
        }
        updateTrayMenu();
      },
      onSessionEnd: (session) => {
        if (appState.mainWindow) {
          appState.mainWindow.webContents.send('session-ended', session);
        }
        updateTrayMenu();
      }
    });

    // Initialize auto-launcher
    appState.autoLauncher = new AutoLaunch({
      name: 'Screen Time Tracker',
      path: app.getPath('exe')
    });

    // Set auto-launch based on settings
    const autoStart = appState.store.get('autoStart');
    if (autoStart) {
      await appState.autoLauncher.enable();
    } else {
      await appState.autoLauncher.disable();
    }

    // Start activity monitoring
    appState.activityMonitor.start();

    console.log('All services initialized successfully');
  } catch (error) {
    console.error('Failed to initialize services:', error);
    throw error;
  }
}

/**
 * Sets up IPC handlers for renderer communication
 * @returns {void}
 */
function setupIPCHandlers() {
  // Get today's sessions
  ipcMain.handle('get-today-sessions', async () => {
    try {
      return appState.database.getTodaySessions();
    } catch (error) {
      console.error('Error getting today sessions:', error);
      throw error;
    }
  });

  // Get sessions by date range
  ipcMain.handle('get-sessions-by-range', async (event, { startDate, endDate }) => {
    try {
      return appState.database.getSessionsByDateRange(startDate, endDate);
    } catch (error) {
      console.error('Error getting sessions by range:', error);
      throw error;
    }
  });

  // Get daily summaries
  ipcMain.handle('get-daily-summaries', async (event, { startDate, endDate }) => {
    try {
      return appState.database.getDailySummaries(startDate, endDate);
    } catch (error) {
      console.error('Error getting daily summaries:', error);
      throw error;
    }
  });

  // Get current session
  ipcMain.handle('get-current-session', async () => {
    try {
      return appState.activityMonitor.getCurrentSession();
    } catch (error) {
      console.error('Error getting current session:', error);
      throw error;
    }
  });

  // Get settings
  ipcMain.handle('get-settings', async () => {
    try {
      return {
        idleThreshold: appState.store.get('idleThreshold'),
        minSessionDuration: appState.store.get('minSessionDuration'),
        autoStart: appState.store.get('autoStart'),
        darkMode: appState.store.get('darkMode'),
        dataRetentionDays: appState.store.get('dataRetentionDays'),
        scheduledPauses: appState.store.get('scheduledPauses')
      };
    } catch (error) {
      console.error('Error getting settings:', error);
      throw error;
    }
  });

  // Update settings
  ipcMain.handle('update-settings', async (event, settings) => {
    try {
      Object.entries(settings).forEach(([key, value]) => {
        appState.store.set(key, value);
      });

      // Update auto-launch if changed
      if ('autoStart' in settings) {
        if (settings.autoStart) {
          await appState.autoLauncher.enable();
        } else {
          await appState.autoLauncher.disable();
        }
      }

      // Update activity monitor settings
      appState.activityMonitor.updateSettings({
        idleThreshold: appState.store.get('idleThreshold'),
        minSessionDuration: appState.store.get('minSessionDuration'),
        scheduledPauses: appState.store.get('scheduledPauses')
      });

      return { success: true };
    } catch (error) {
      console.error('Error updating settings:', error);
      throw error;
    }
  });

  // Pause/Resume tracking
  ipcMain.handle('toggle-tracking', async (event, pause) => {
    try {
      if (pause) {
        appState.activityMonitor.pause();
      } else {
        appState.activityMonitor.resume();
      }
      updateTrayMenu();
      return { success: true, isPaused: appState.activityMonitor.isPaused() };
    } catch (error) {
      console.error('Error toggling tracking:', error);
      throw error;
    }
  });

  // Get tracking status
  ipcMain.handle('get-tracking-status', async () => {
    try {
      return {
        isPaused: appState.activityMonitor.isPaused(),
        isMonitoring: appState.activityMonitor.isMonitoring()
      };
    } catch (error) {
      console.error('Error getting tracking status:', error);
      throw error;
    }
  });

  // Export to PDF
  ipcMain.handle('export-pdf', async (event, { startDate, endDate, filePath }) => {
    try {
      await appState.exportService.exportToPDF(startDate, endDate, filePath);
      return { success: true };
    } catch (error) {
      console.error('Error exporting to PDF:', error);
      throw error;
    }
  });

  // Export to CSV
  ipcMain.handle('export-csv', async (event, { startDate, endDate, filePath }) => {
    try {
      await appState.exportService.exportToCSV(startDate, endDate, filePath);
      return { success: true };
    } catch (error) {
      console.error('Error exporting to CSV:', error);
      throw error;
    }
  });

  // Get statistics
  ipcMain.handle('get-statistics', async (event, { period }) => {
    try {
      return appState.database.getStatistics(period);
    } catch (error) {
      console.error('Error getting statistics:', error);
      throw error;
    }
  });

  // Delete old data
  ipcMain.handle('delete-old-data', async (event, { days }) => {
    try {
      const deletedCount = appState.database.deleteOldData(days);
      return { success: true, deletedCount };
    } catch (error) {
      console.error('Error deleting old data:', error);
      throw error;
    }
  });

  // Show save dialog
  ipcMain.handle('show-save-dialog', async (event, { defaultPath, filters }) => {
    const { dialog } = require('electron');
    const result = await dialog.showSaveDialog(appState.mainWindow, {
      defaultPath,
      filters
    });
    return result;
  });
}

// App lifecycle events
app.whenReady().then(async () => {
  try {
    await initializeServices();
    createWindow();
    createTray();
    setupIPCHandlers();

    app.on('activate', () => {
      if (BrowserWindow.getAllWindows().length === 0) {
        createWindow();
      }
    });
  } catch (error) {
    console.error('Failed to start application:', error);
    app.quit();
  }
});

app.on('window-all-closed', () => {
  if (process.platform !== 'darwin') {
    // Don't quit, keep running in tray
  }
});

app.on('before-quit', () => {
  app.isQuitting = true;
  if (appState.activityMonitor) {
    appState.activityMonitor.stop();
  }
  if (appState.database) {
    appState.database.close();
  }
});

