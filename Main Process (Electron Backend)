const Database = require('better-sqlite3');
const path = require('path');
const { format, subDays, startOfDay, endOfDay } = require('date-fns');

/**
 * @typedef {Object} Session
 * @property {number} id - Session ID
 * @property {string} start_time - Session start time (ISO string)
 * @property {string|null} end_time - Session end time (ISO string)
 * @property {number} duration - Duration in seconds
 * @property {string} date - Session date (YYYY-MM-DD)
 */

/**
 * @typedef {Object} DailySummary
 * @property {number} id - Summary ID
 * @property {string} date - Date (YYYY-MM-DD)
 * @property {number} total_duration - Total duration in seconds
 * @property {number} session_count - Number of sessions
 * @property {number} average_session - Average session duration in seconds
 */

/**
 * Database manager for screen time tracking
 */
class ScreenTimeDatabase {
  /**
   * Creates a new database instance
   * @param {string} dbPath - Path to the SQLite database file
   */
  constructor(dbPath) {
    this.dbPath = dbPath;
    this.db = null;
    this.initialize();
  }

  /**
   * Initializes the database connection and creates tables
   * @returns {void}
   */
  initialize() {
    try {
      this.db = new Database(this.dbPath);
      this.db.pragma('journal_mode = WAL');
      this.createTables();
      this.runMigrations();
      console.log('Database initialized successfully');
    } catch (error) {
      console.error('Failed to initialize database:', error);
      throw error;
    }
  }

  /**
   * Creates the database tables
   * @returns {void}
   */
  createTables() {
    // Sessions table
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS sessions (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        start_time TEXT NOT NULL,
        end_time TEXT,
        duration INTEGER DEFAULT 0,
        date TEXT NOT NULL,
        created_at TEXT DEFAULT CURRENT_TIMESTAMP,
        updated_at TEXT DEFAULT CURRENT_TIMESTAMP
      )
    `);

    // Daily summaries table
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS daily_summaries (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        date TEXT UNIQUE NOT NULL,
        total_duration INTEGER DEFAULT 0,
        session_count INTEGER DEFAULT 0,
        average_session INTEGER DEFAULT 0,
        created_at TEXT DEFAULT CURRENT_TIMESTAMP,
        updated_at TEXT DEFAULT CURRENT_TIMESTAMP
      )
    `);

    // Settings table
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS settings (
        key TEXT PRIMARY KEY,
        value TEXT NOT NULL,
        created_at TEXT DEFAULT CURRENT_TIMESTAMP,
        updated_at TEXT DEFAULT CURRENT_TIMESTAMP
      )
    `);

    // Schema version table for migrations
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS schema_version (
        version INTEGER PRIMARY KEY,
        applied_at TEXT DEFAULT CURRENT_TIMESTAMP
      )
    `);

    // Create indexes for better query performance
    this.db.exec(`
      CREATE INDEX IF NOT EXISTS idx_sessions_date ON sessions(date);
      CREATE INDEX IF NOT EXISTS idx_sessions_start_time ON sessions(start_time);
      CREATE INDEX IF NOT EXISTS idx_daily_summaries_date ON daily_summaries(date);
    `);
  }

  /**
   * Runs database migrations
   * @returns {void}
   */
  runMigrations() {
    const currentVersion = this.getSchemaVersion();
    const migrations = [
      // Migration 1: Add indexes
      () => {
        this.db.exec(`
          CREATE INDEX IF NOT EXISTS idx_sessions_duration ON sessions(duration);
        `);
      },
      // Migration 2: Add hourly breakdown column
      () => {
        try {
          this.db.exec(`
            ALTER TABLE daily_summaries ADD COLUMN hourly_breakdown TEXT;
          `);
        } catch (e) {
          // Column might already exist
        }
      }
    ];

    for (let i = currentVersion; i < migrations.length; i++) {
      try {
        migrations[i]();
        this.setSchemaVersion(i + 1);
        console.log(`Applied migration ${i + 1}`);
      } catch (error) {
        console.error(`Failed to apply migration ${i + 1}:`, error);
      }
    }
  }

  /**
   * Gets the current schema version
   * @returns {number} Current schema version
   */
  getSchemaVersion() {
    try {
      const row = this.db.prepare('SELECT MAX(version) as version FROM schema_version').get();
      return row?.version || 0;
    } catch {
      return 0;
    }
  }

  /**
   * Sets the schema version
   * @param {number} version - New schema version
   * @returns {void}
   */
  setSchemaVersion(version) {
    this.db.prepare('INSERT OR REPLACE INTO schema_version (version) VALUES (?)').run(version);
  }

  /**
   * Starts a new session
   * @param {Date} startTime - Session start time
   * @returns {number} New session ID
   */
  startSession(startTime = new Date()) {
    const dateStr = format(startTime, 'yyyy-MM-dd');
    const startTimeStr = startTime.toISOString();

    const result = this.db.prepare(`
      INSERT INTO sessions (start_time, date) VALUES (?, ?)
    `).run(startTimeStr, dateStr);

    return result.lastInsertRowid;
  }

  /**
   * Ends an active session
   * @param {number} sessionId - Session ID to end
   * @param {Date} endTime - Session end time
   * @returns {Session|null} Updated session or null
   */
  endSession(sessionId, endTime = new Date()) {
    const session = this.getSession(sessionId);
    if (!session) return null;

    const endTimeStr = endTime.toISOString();
    const startTime = new Date(session.start_time);
    const duration = Math.floor((endTime - startTime) / 1000);

    this.db.prepare(`
      UPDATE sessions 
      SET end_time = ?, duration = ?, updated_at = CURRENT_TIMESTAMP
      WHERE id = ?
    `).run(endTimeStr, duration, sessionId);

    // Update daily summary
    this.updateDailySummary(session.date);

    return this.getSession(sessionId);
  }

  /**
   * Updates session duration (for active sessions)
   * @param {number} sessionId - Session ID
   * @param {number} duration - Current duration in seconds
   * @returns {void}
   */
  updateSessionDuration(sessionId, duration) {
    this.db.prepare(`
      UPDATE sessions SET duration = ?, updated_at = CURRENT_TIMESTAMP WHERE id = ?
    `).run(duration, sessionId);
  }

  /**
   * Gets a session by ID
   * @param {number} sessionId - Session ID
   * @returns {Session|null} Session object or null
   */
  getSession(sessionId) {
    return this.db.prepare('SELECT * FROM sessions WHERE id = ?').get(sessionId);
  }

  /**
   * Gets today's sessions
   * @returns {Session[]} Array of today's sessions
   */
  getTodaySessions() {
    const today = format(new Date(), 'yyyy-MM-dd');
    return this.db.prepare(`
      SELECT * FROM sessions WHERE date = ? ORDER BY start_time DESC
    `).all(today);
  }

  /**
   * Gets sessions within a date range
   * @param {string} startDate - Start date (YYYY-MM-DD)
   * @param {string} endDate - End date (YYYY-MM-DD)
   * @returns {Session[]} Array of sessions
   */
  getSessionsByDateRange(startDate, endDate) {
    return this.db.prepare(`
      SELECT * FROM sessions 
      WHERE date >= ? AND date <= ?
      ORDER BY start_time DESC
    `).all(startDate, endDate);
  }

  /**
   * Gets daily summaries within a date range
   * @param {string} startDate - Start date (YYYY-MM-DD)
   * @param {string} endDate - End date (YYYY-MM-DD)
   * @returns {DailySummary[]} Array of daily summaries
   */
  getDailySummaries(startDate, endDate) {
    return this.db.prepare(`
      SELECT * FROM daily_summaries 
      WHERE date >= ? AND date <= ?
      ORDER BY date ASC
    `).all(startDate, endDate);
  }

  /**
   * Updates the daily summary for a specific date
   * @param {string} date - Date (YYYY-MM-DD)
   * @returns {void}
   */
  updateDailySummary(date) {
    const stats = this.db.prepare(`
      SELECT 
        COUNT(*) as session_count,
        COALESCE(SUM(duration), 0) as total_duration,
        COALESCE(AVG(duration), 0) as average_session
      FROM sessions 
      WHERE date = ? AND end_time IS NOT NULL
    `).get(date);

    this.db.prepare(`
      INSERT OR REPLACE INTO daily_summaries 
      (date, total_duration, session_count, average_session, updated_at)
      VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP)
    `).run(date, stats.total_duration, stats.session_count, Math.floor(stats.average_session));
  }

  /**
   * Gets statistics for a specific period
   * @param {'day'|'week'|'month'|'year'} period - Time period
   * @returns {Object} Statistics object
   */
  getStatistics(period) {
    const now = new Date();
    let startDate;

    switch (period) {
      case 'day':
        startDate = format(now, 'yyyy-MM-dd');
        break;
      case 'week':
        startDate = format(subDays(now, 7), 'yyyy-MM-dd');
        break;
      case 'month':
        startDate = format(subDays(now, 30), 'yyyy-MM-dd');
        break;
      case 'year':
        startDate = format(subDays(now, 365), 'yyyy-MM-dd');
        break;
      default:
        startDate = format(now, 'yyyy-MM-dd');
    }

    const endDate = format(now, 'yyyy-MM-dd');

    const stats = this.db.prepare(`
      SELECT 
        COUNT(*) as total_sessions,
        COALESCE(SUM(duration), 0) as total_duration,
        COALESCE(AVG(duration), 0) as average_session,
        COALESCE(MAX(duration), 0) as longest_session,
        COUNT(DISTINCT date) as active_days
      FROM sessions 
      WHERE date >= ? AND date <= ? AND end_time IS NOT NULL
    `).get(startDate, endDate);

    const dailyData = this.getDailySummaries(startDate, endDate);

    return {
      ...stats,
      average_session: Math.floor(stats.average_session),
      dailyData,
      period,
      startDate,
      endDate
    };
  }

  /**
   * Deletes data older than specified days
   * @param {number} days - Number of days to retain
   * @returns {number} Number of deleted records
   */
  deleteOldData(days) {
    const cutoffDate = format(subDays(new Date(), days), 'yyyy-MM-dd');
    
    const sessionsDeleted = this.db.prepare(`
      DELETE FROM sessions WHERE date < ?
    `).run(cutoffDate);

    const summariesDeleted = this.db.prepare(`
      DELETE FROM daily_summaries WHERE date < ?
    `).run(cutoffDate);

    return sessionsDeleted.changes + summariesDeleted.changes;
  }

  /**
   * Gets a setting value
   * @param {string} key - Setting key
   * @param {*} defaultValue - Default value if not found
   * @returns {*} Setting value
   */
  getSetting(key, defaultValue = null) {
    const row = this.db.prepare('SELECT value FROM settings WHERE key = ?').get(key);
    if (row) {
      try {
        return JSON.parse(row.value);
      } catch {
        return row.value;
      }
    }
    return defaultValue;
  }

  /**
   * Sets a setting value
   * @param {string} key - Setting key
   * @param {*} value - Setting value
   * @returns {void}
   */
  setSetting(key, value) {
    const valueStr = typeof value === 'object' ? JSON.stringify(value) : String(value);
    this.db.prepare(`
      INSERT OR REPLACE INTO settings (key, value, updated_at) 
      VALUES (?, ?, CURRENT_TIMESTAMP)
    `).run(key, valueStr);
  }

  /**
   * Closes the database connection
   * @returns {void}
   */
  close() {
    if (this.db) {
      this.db.close();
      console.log('Database connection closed');
    }
  }
}

module.exports = ScreenTimeDatabase;

