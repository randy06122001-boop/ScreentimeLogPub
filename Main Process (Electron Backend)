const { contextBridge, ipcRenderer } = require('electron');

/**
 * Exposes secure API to renderer process
 */
contextBridge.exposeInMainWorld('electronAPI', {
  // Session management
  getTodaySessions: () => ipcRenderer.invoke('get-today-sessions'),
  getSessionsByRange: (startDate, endDate) => 
    ipcRenderer.invoke('get-sessions-by-range', { startDate, endDate }),
  getDailySummaries: (startDate, endDate) => 
    ipcRenderer.invoke('get-daily-summaries', { startDate, endDate }),
  getCurrentSession: () => ipcRenderer.invoke('get-current-session'),
  
  // Settings
  getSettings: () => ipcRenderer.invoke('get-settings'),
  updateSettings: (settings) => ipcRenderer.invoke('update-settings', settings),
  
  // Tracking control
  toggleTracking: (pause) => ipcRenderer.invoke('toggle-tracking', pause),
  getTrackingStatus: () => ipcRenderer.invoke('get-tracking-status'),
  
  // Export
  exportPDF: (startDate, endDate, filePath) => 
    ipcRenderer.invoke('export-pdf', { startDate, endDate, filePath }),
  exportCSV: (startDate, endDate, filePath) => 
    ipcRenderer.invoke('export-csv', { startDate, endDate, filePath }),
  showSaveDialog: (options) => ipcRenderer.invoke('show-save-dialog', options),
  
  // Statistics
  getStatistics: (period) => ipcRenderer.invoke('get-statistics', { period }),
  
  // Data management
  deleteOldData: (days) => ipcRenderer.invoke('delete-old-data', { days }),
  
  // Event listeners
  onSessionUpdate: (callback) => {
    ipcRenderer.on('session-update', (event, session) => callback(session));
    return () => ipcRenderer.removeAllListeners('session-update');
  },
  onSessionEnded: (callback) => {
    ipcRenderer.on('session-ended', (event, session) => callback(session));
    return () => ipcRenderer.removeAllListeners('session-ended');
  },
  onNavigate: (callback) => {
    ipcRenderer.on('navigate', (event, route) => callback(route));
    return () => ipcRenderer.removeAllListeners('navigate');
  }
});

